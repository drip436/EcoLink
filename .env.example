# .env.example - Copiar a .env y ajustar valores
# ========================================

# BASE DE DATOS - PostgreSQL
# Si usas PostgreSQL en tu máquina local:
DATABASE_URL=postgresql://postgres:password@localhost:5432/ecolink
# Si usas SQLite (desarrollo simple, no recomendado para producción):
# DATABASE_URL=sqlite:///./test.db

# AUTENTICACIÓN JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CONFIGURACIÓN DE LA APLICACIÓN  
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# GAMIFICACIÓN
BASE_POINTS_PER_COLLECTION=10
BASE_POINTS_PER_RECYCLING_POINT=5
POINTS_PER_LEVEL=100
