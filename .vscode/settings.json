{
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  "python.pythonPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.formatOnSave": true
  },
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": false,
  "python.linting.flake8Enabled": true,
  "python.formatting.provider": "black",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "ms-python.python",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/backend",
    "${workspaceFolder}/frontend"
  ],
  "python.analysis.excludeModules": [
    "reflex",
    "rx"
  ],
  "python.analysis.ignore": [
    "*"
  ],
  "python.analysis.reportMissingImports": false,
  "python.analysis.reportMissingTypeStubs": false,
  "python.analysis.reportOptionalMemberAccess": false,
  "python.analysis.reportOptionalSubscript": false,
  "python.linting.pylintArgs": [
    "--disable=all"
  ],
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/node_modules": true,
    "**/.web": true
  },
  "search.exclude": {
    "**/__pycache__": true,
    "**/node_modules": true,
    "**/.web": true,
    "**/.venv": true
  },
  "python-envs.defaultEnvManager": "ms-python.python:system"
}
